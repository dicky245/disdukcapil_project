VITE_APP_NAME="${APP_NAME}"
CSP_ENABLED=false
CSP_REPORT_ONLY=false

# =============================================
# EasyOCR Configuration (Primary OCR)
# =============================================
# Set false untuk menggunakan EasyOCR sungguhan
EASYOCR_MOCK_ENABLED=false

# Gunakan Flask API (true) atau CLI mode (false)
# Flask API: python scripts/easyocr_ktp.py (tanpa argumen)
EASYOCR_USE_API=false

# Flask API host dan port
EASYOCR_API_HOST=127.0.0.1
EASYOCR_API_PORT=5000

# Path ke Python executable
EASYOCR_PYTHON_PATH=python

# Timeout untuk proses OCR (detik)
EASYOCR_TIMEOUT=120

# GPU mode (jika tersedia)
EASYOCR_USE_GPU=false